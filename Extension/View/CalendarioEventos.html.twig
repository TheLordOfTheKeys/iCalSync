{% extends 'PlanetaEscenario/View/CalendarioEventos.html.twig' %}

{% block body %}
    <div class="container-fluid mb-3">
        <div class="row">
            <div class="col-12">
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-sm btn-outline-info" onclick="ICalSync.showSyncStatus()">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        {{ trans('sync-status') }}
                        {% if settings('icalsync', 'unsynced_eventos', '0') > 0 or settings('icalsync', 'unsynced_citas', '0') > 0 %}
                            <span class="badge bg-warning ms-1">
                                {{ settings('icalsync', 'unsynced_eventos', '0') + settings('icalsync', 'unsynced_citas', '0') }}
                            </span>
                        {% endif %}
                    </button>
                </div>
            </div>
        </div>
    </div>

    {{ parent() }}

    <!-- Sync status modal -->
    <div class="modal fade" id="icalsync-status-modal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ trans('sync-status') }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>{{ trans('entity') }}</th>
                                    <th>{{ trans('pending-sync') }}</th>
                                    <th>{{ trans('synced') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>{{ trans('events') }}</td>
                                    <td>
                                        <span class="badge bg-warning">
                                            {{ settings('icalsync', 'unsynced_eventos', '0') }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">{{ trans('data-unavailable') }}</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>{{ trans('appointments') }}</td>
                                    <td>
                                        <span class="badge bg-warning">
                                            {{ settings('icalsync', 'unsynced_citas', '0') }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">{{ trans('data-unavailable') }}</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        {{ trans('close') }}
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        const ICalSync = {
            showSyncStatus: function() {
                const modal = new bootstrap.Modal(document.getElementById('icalsync-status-modal'));
                modal.show();
            }
        };
    </script>
{% endblock %}
