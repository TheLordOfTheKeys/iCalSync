<?xml version="1.0" encoding="UTF-8"?>
<!--
    Document   : icalsync_items.xml
    Description:
        Estructura de la tabla icalsync_items.
        Mapea entidades FS (Evento/Cita) con UIDs de CalDAV.
-->
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>entity_type</name>
        <type>character varying(50)</type>
        <null>NO</null>
    </column>
    <column>
        <name>entity_id</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>calendar_id</name>
        <type>integer</type>
    </column>
    <column>
        <name>caldav_uid</name>
        <type>character varying(255)</type>
        <null>NO</null>
    </column>
    <column>
        <name>caldav_etag</name>
        <type>character varying(255)</type>
    </column>
    <column>
        <name>direction</name>
        <type>character varying(20)</type>
        <null>NO</null>
    </column>
    <column>
        <name>last_sync_at</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>sync_status</name>
        <type>character varying(20)</type>
        <null>NO</null>
    </column>
    <column>
        <name>origin</name>
        <type>character varying(10)</type>
    </column>
    <column>
        <name>error_message</name>
        <type>text</type>
    </column>
    <constraint>
        <name>icalsync_items_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_items_calendar</name>
        <type>FOREIGN KEY (calendar_id) REFERENCES icalsync_calendars (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>un_items_entity</name>
        <type>UNIQUE (entity_type, entity_id)</type>
    </constraint>
    <constraint>
        <name>un_items_caldav_uid</name>
        <type>UNIQUE (caldav_uid)</type>
    </constraint>
</table>
