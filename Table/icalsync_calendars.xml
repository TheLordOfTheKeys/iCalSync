<?xml version="1.0" encoding="UTF-8"?>
<!--
    Document   : icalsync_calendars.xml
    Description:
        Estructura de la tabla icalsync_calendars.
        Almacena los calendarios descubiertos de cada cuenta iCloud.
-->
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>account_id</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>calendar_name</name>
        <type>character varying(200)</type>
        <null>NO</null>
    </column>
    <column>
        <name>calendar_url</name>
        <type>character varying(500)</type>
        <null>NO</null>
    </column>
    <column>
        <name>calendar_color</name>
        <type>character varying(10)</type>
    </column>
    <column>
        <name>ctag</name>
        <type>character varying(255)</type>
    </column>
    <column>
        <name>sync_token</name>
        <type>text</type>
    </column>
    <column>
        <name>calendar_type</name>
        <type>character varying(20)</type>
    </column>
    <column>
        <name>enabled</name>
        <type>boolean</type>
        <null>NO</null>
        <default>true</default>
    </column>
    <column>
        <name>last_sync_at</name>
        <type>timestamp</type>
    </column>
    <constraint>
        <name>icalsync_calendars_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_calendars_account</name>
        <type>FOREIGN KEY (account_id) REFERENCES icalsync_accounts (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
